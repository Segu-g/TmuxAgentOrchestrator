          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/TaskPriorityUpdate"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "additionalProperties": true,
                  "title": "Response Update Task Priority Tasks  Task Id  Patch",
                  "type": "object"
                }
              }
            },
