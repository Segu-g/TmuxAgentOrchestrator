    "/tasks/batch": {
      "post": {
        "description": "Submit a list of tasks atomically.\n\nAll tasks in the batch are validated before any are enqueued.  If the\nrequest body is malformed, FastAPI returns 422 before this handler runs.\n\nDesign reference:\n- adidas API Guidelines \"Batch Operations\"\n  https://adidas.gitbook.io/api-guidelines/rest-api-guidelines/execution/batch-operations\n- PayPal Batch API (Medium, PayPal Tech Blog)\n  https://medium.com/paypal-tech/batch-an-api-to-bundle-multiple-paypal-rest-operations-6af6006e002",
        "operationId": "submit_tasks_batch_tasks_batch_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/TaskBatchSubmit"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "additionalProperties": true,
                  "title": "Response Submit Tasks Batch Tasks Batch Post",
                  "type": "object"
                }
              }
            },
            "description": "Successful Response"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "summary": "Submit multiple tasks in one request"
      }
    },
    "/tasks/{task_id}/cancel": {
      "post": {
        "description": "Remove *task_id* from the pending queue and discard it.\n\nReturns:\n- ``{\"cancelled\": true, \"task_id\": ..., \"status\": \"cancelled\"}``\n  if the task was successfully removed from the queue.\n- ``{\"cancelled\": false, \"task_id\": ..., \"status\": \"already_dispatched\"}``\n  if the task was not in the pending queue (already dispatched or\n  currently in-flight).\n- ``404`` if the task ID has never been submitted or tracked.\n\nDesign reference: Microsoft Azure \"Asynchronous Request-Reply pattern\"\n(2024): \"A client can send an HTTP DELETE request on the URL provided\nby Location header when the task is submitted.\" We use POST on a verb\nsub-resource (action endpoint) since DELETE on /tasks/{id} could be\nambiguous with resource deletion semantics.\nDESIGN.md \u00a711 (v0.17.0) \u2014 task cancellation.",
        "operationId": "cancel_task_tasks__task_id__cancel_post",
        "parameters": [
          {
            "in": "path",
            "name": "task_id",
            "required": true,
            "schema": {
              "title": "Task Id",
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "additionalProperties": true,
                  "title": "Response Cancel Task Tasks  Task Id  Cancel Post",
                  "type": "object"
                }
              }
            },
            "description": "Successful Response"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "summary": "Cancel a pending task"
      }
    }
  }
